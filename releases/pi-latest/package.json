{
	"name": "pijs-web",
	"version": "2.0.2",
	"majorVersion": "2.0",
	"description": "Retro2D graphics, sound, and input library for javascript",
	"types": "dist/pi.d.ts",
	"browser": "dist/pi.js",
	"unpkg": "dist/pi.min.js",
	"jsdelivr": "dist/pi.min.js",
	"files": [
		"dist"
	],
	"exports": {
		".": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/pi.js",
			"import": "./dist/pi.esm.js",
			"default": "./dist/pi.esm.js"
		},
		"./lite": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/pi.lite.js",
			"import": "./dist/pi.lite.esm.js",
			"default": "./dist/pi.lite.esm.js"
		},
		"./plugins/gamepad": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/plugins/gamepad/gamepad.js",
			"import": "./dist/plugins/gamepad/gamepad.esm.js",
			"default": "./dist/plugins/gamepad/gamepad.esm.js"
		},
		"./plugins/keyboard": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/plugins/keyboard/keyboard.js",
			"import": "./dist/plugins/keyboard/keyboard.esm.js",
			"default": "./dist/plugins/keyboard/keyboard.esm.js"
		},
		"./plugins/pointer": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/plugins/pointer/pointer.js",
			"import": "./dist/plugins/pointer/pointer.esm.js",
			"default": "./dist/plugins/pointer/pointer.esm.js"
		},
		"./plugins/sound": {
			"types": "./dist/pi.d.ts",
			"browser": "./dist/plugins/sound/sound.js",
			"import": "./dist/plugins/sound/sound.esm.js",
			"default": "./dist/plugins/sound/sound.esm.js"
		}
	},
	"repository": {
		"type": "git",
		"url": "git+https://github.com/AndyStubbs/pijs"
	},
	"author": "Andy Stubbs <andy@pijs.org>",
	"license": "Apache-2.0",
	"bugs": {
		"url": "https://github.com/AndyStubbs/pijs/issues"
	},
	"homepage": "https://www.pijs.org",
	"keywords": [
		"2d",
		"graphics",
		"webgl",
		"canvas",
		"retro",
		"game-engine",
		"game-dev",
		"input",
		"sound",
		"javascript",
		"browser-game",
		"pixel-art"
	]
}
